 	ALC269_FIXUP_HEADSET_MODE_NO_HP_MIC,
 	ALC269_FIXUP_ASPIRE_HEADSET_MIC,
 	ALC269_FIXUP_ASUS_X101_FUNC,
@@ -7878,6 +7894,30 @@ enum {
 	ALC283_FIXUP_DELL_HP_RESUME,
 };
 
