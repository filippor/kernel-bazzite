diff --git a/drivers/leds/Kconfig b/drivers/leds/Kconfig
index b784bb74a8378..f8d8fcfacac22 100644
--- a/drivers/leds/Kconfig
+++ b/drivers/leds/Kconfig
@@ -941,6 +941,18 @@ config LEDS_TPS6105X
